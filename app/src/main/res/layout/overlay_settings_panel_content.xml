<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/opacity"
            android:textColor="@color/body_color" />

        <TextView
            android:id="@+id/textOpacityValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/body_color"
            android:textStyle="bold" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekOpacity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <CheckBox
        android:id="@+id/checkTrueOpaqueMask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/true_opaque_mask"
        android:textColor="@color/body_color" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/overlay_width"
            android:textColor="@color/body_color" />

        <TextView
            android:id="@+id/textWidthValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/body_color"
            android:textStyle="bold" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekOverlayWidth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/overlay_top"
            android:textColor="@color/body_color" />

        <TextView
            android:id="@+id/textTopValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/body_color"
            android:textStyle="bold" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekOverlayTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/overlay_bottom"
            android:textColor="@color/body_color" />

        <TextView
            android:id="@+id/textBottomValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/body_color"
            android:textStyle="bold" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekOverlayBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/peek_windows"
            android:textColor="@color/body_color" />

        <TextView
            android:id="@+id/textPeekCountValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/body_color"
            android:textStyle="bold" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekPeekCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/button_opacity"
            android:textColor="@color/body_color" />

        <TextView
            android:id="@+id/textToolbarOpacityValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/body_color"
            android:textStyle="bold" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekToolbarOpacity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/overlay_off_animation"
        android:textColor="@color/body_color" />

    <Spinner
        android:id="@+id/spinnerDismissAnimation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp" />
</LinearLayout>
